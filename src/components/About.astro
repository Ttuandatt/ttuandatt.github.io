---
import { Image } from "astro:assets";
import Avatar from "../anhthe.jpg";
import { SectionTitle } from "./UI";
import { getLangFromUrl, useTranslations } from "../i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="w-full min-h-screen px-6 py-4 pt-14 bg-background">
    <SectionTitle
        title={t("about.title")}
        color="primary"
        className="h-screen flex flex-col justify-center"
    >
        <div class="flex_center flex-col lg:flex-row w-full h-full py-10 gap-8">
            <Image
                src={Avatar}
                alt="About_Avatar"
                class="Fade_Up rounded-full object-cover lg:mx-14"
                width={225}
                height={225}
                loading="lazy"
            />

            <div
                class="Fade_Up w-full md:w-[80%] lg:w-[60%] flex justify-center items-start flex-col gap-4 lg:border-l border-primary py-8 lg:pl-10"
            >
                <h2 class="Fade_Up text-[1.5em] font-bold">{t("about.hi")}</h2>
                <p class="Fade_Up text-justify" set:html={t("about.bio1")}></p>
                <p class="Fade_Up text-justify">{t("about.bio2")}</p>
                <p class="Fade_Up text-justify">{t("about.bio3")}</p>
                <ul class="Fade_Up text-justify mt-2 text-sm list-disc list-inside">
                    <li><b>{t("about.email")}:</b> pcanhtuandat@gmail.com</li>
                    <li><b>{t("about.phone")}:</b> (+84)867829257</li>
                    <li><b>{t("about.address")}:</b> {t("about.addressValue")}</li>
                    <li><b>{t("about.school")}:</b> {t("about.schoolValue")}</li>
                </ul>
                <div class="Fade_Up flex flex-wrap gap-4 mt-4">
                    <div class="bg-primary/10 rounded-lg px-4 py-2 text-center">
                        <div class="text-lg font-bold">6</div>
                        <div class="text-xs">{t("about.stat.months")}</div>
                    </div>
                    <div class="bg-primary/10 rounded-lg px-4 py-2 text-center">
                        <div class="text-lg font-bold">5</div>
                        <div class="text-xs">{t("about.stat.microservices")}</div>
                    </div>
                    <div class="bg-primary/10 rounded-lg px-4 py-2 text-center">
                        <div class="text-lg font-bold">7.0</div>
                        <div class="text-xs">{t("about.stat.ielts")}</div>
                    </div>
                    <div class="bg-primary/10 rounded-lg px-4 py-2 text-center">
                        <div class="text-lg font-bold">2</div>
                        <div class="text-xs">{t("about.stat.projects")}</div>
                    </div>
                </div>
            </div>
        </div>
    </SectionTitle>
</section>

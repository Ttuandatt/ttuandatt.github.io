---
import { Download } from "lucide-preact";
import { getLangFromUrl, useTranslations, localizePath } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const otherLang = lang === "vi" ? "en" : "vi";
const currentPath = Astro.url.pathname;
const pathWithoutLocale = lang === "vi" ? currentPath : currentPath.replace(/^\/en/, "") || "/";
const switchHref =
    otherLang === "vi"
        ? pathWithoutLocale
        : `/en${pathWithoutLocale === "/" ? "/" : pathWithoutLocale}`;
---

<header class="hidden lg:block sticky top-0 z-50">
    <div
        class="flex justify-between items-center w-full px-6 py-2 bg-headerGradient backdrop-blur-[2px]"
    >
        <a href={localizePath("/", lang)} class="Fade_Down font-satisfy font-bold text-[2em]">
            <span class="gradientText w-fit">Portfolio.</span>
        </a>

        <div class="Header_Nav flex gap-6">
            <a class="Fade_Down" href={localizePath("/#about", lang)}>{t("nav.about")}</a>
            <a class="Fade_Down" href={localizePath("/#skills", lang)}>{t("nav.skills")}</a>
            <a class="Fade_Down" href={localizePath("/#projects", lang)}>{t("nav.projects")}</a>
            <a class="Fade_Down" href={localizePath("/#contact", lang)}>{t("nav.contact")}</a>
        </div>

        <div class="flex_center gap-4">
            <a
                class="Fade_Down Lang_Switch text-sm font-semibold tracking-wider"
                href={switchHref}
                aria-label={`Switch to ${t("lang.switchTo")}`}
                title={t("lang.switchTo")}
            >
                {otherLang.toUpperCase()}
            </a>

            <a
                class="Fade_Down Header_ActionBtn"
                href="/CV_SoftDev.pdf"
                target="_blank"
                rel="noreferrer"
                download
            >
                <div class="flex_center gap-2">
                    <p>{t("nav.resume")}</p>
                    <Download size={18} />
                </div>
            </a>
        </div>
    </div>
</header>

<!-- Mobile Header -->
<header
    class="lg:hidden w-full sticky top-0 z-50 bg-headerGradient backdrop-blur-[2px]"
>
    <div class="flex justify-between items-center py-2 px-4">
        <a href={localizePath("/", lang)} class="Fade_In font-satisfy font-bold text-[2em]">
            <span class="gradientText w-fit">Portfolio.</span>
        </a>

        <svg
            viewBox="20 20 60 60"
            width="45"
            class="Fade_In MobileNav_Ham flex justify-center items-end flex-col gap-2 z-[70] cursor-pointer"
            id="Ham_Menu"
        >
            <path
                class="line top"
                d="m 30,33 h 40 c 3.722839,0 7.5,3.126468 7.5,8.578427 0,5.451959 -2.727029,8.421573 -7.5,8.421573 h -20"
            ></path>
            <path class="line middle" d="m 30,50 h 40"></path>
            <path
                class="line bottom"
                d="m 70,67 h -40 c 0,0 -7.5,-0.802118 -7.5,-8.365747 0,-7.563629 7.5,-8.634253 7.5,-8.634253 h 20"
            ></path>
        </svg>
    </div>

    <div
        id="mobileHeaderNav"
        style="clip-path: circle(30px at calc(100vw + 30px) -30px);"
        class="w-full h-dvh flex_center flex-col fixed top-0 right-0 gap-8 z-[60]"
    >
        <div class="MobileHeader_Nav flex_center">
            <a href={localizePath("/#about", lang)}>{t("nav.about")}</a>
        </div>

        <div class="MobileHeader_Nav flex_center">
            <a href={localizePath("/#skills", lang)}>{t("nav.skills")}</a>
        </div>

        <div class="MobileHeader_Nav flex_center">
            <a href={localizePath("/#projects", lang)}>{t("nav.projects")}</a>
        </div>

        <div class="MobileHeader_Nav flex_center">
            <a href={localizePath("/#contact", lang)}>{t("nav.contact")}</a>
        </div>

        <div class="MobileHeader_Nav flex_center">
            <a href={switchHref}>{t("lang.switchTo")}</a>
        </div>

        <div class="MobileHeader_Nav flex_center">
            <a
                class="MobileHeader_ActionBtn flex_center"
                href="/CV_SoftDev.pdf"
                target="_blank"
                rel="noreferrer"
                download
            >
                <div class="flex_center gap-4">
                    <p>{t("nav.resume")}</p>
                    <Download />
                </div>
            </a>
        </div>
    </div>
</header>
